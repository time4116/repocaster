# GitHub App mode
GITHUB_APP_ID=123456
GITHUB_SECRET_NAME=repocaster/github
ALLOWED_REPOS=time4116/repocaster,time4116/bedrock-pr-agent
ALLOWED_USERS=time4116
WEEKLY_EXECUTION_LIMIT=2
GLOBAL_WEEKLY_EXECUTION_LIMIT=5

# AI/audio
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE_A=nova
OPENAI_TTS_VOICE_B=shimmer

# Output/cost controls
OUTPUT_BUCKET=repocaster-output-example
AWS_ROLE_ARN=<set as GitHub secret; do not commit a real ARN>
S3_PRESIGNED_URL_TTL_SECONDS=604800
S3_RETENTION_DAYS=10
MIN_EPISODE_MINUTES=6
MAX_EPISODE_MINUTES=8
TARGET_SCRIPT_WORDS=1050
MIN_SCRIPT_WORDS=900
MAX_SCRIPT_WORDS=1250
MAX_SEGMENTS=22
MAX_CONTEXT_CHARS=50000
MAX_FILES=40
MAX_FILE_CHARS=8000
